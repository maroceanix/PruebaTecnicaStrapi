{
  "kind": "collectionType",
  "collectionName": "platoes",
  "info": {
    "singularName": "plato",
    "pluralName": "platoes",
    "displayName": "Plato"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string"
    },
    "precio_plato": {
