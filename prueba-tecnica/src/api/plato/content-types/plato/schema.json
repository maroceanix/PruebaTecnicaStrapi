      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "tipo": {
      "type": "enumeration",
      "enum": [
        "Primero",
        "Segundo",
        "Postre"
      ]
    },
    "alergenos": {
      "type": "component",
      "component": "alergenos.alergenos",
      "repeatable": true
    }
  }
}
